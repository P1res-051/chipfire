#############################################
# EVO CRM — Central de Relacionamento WhatsApp
# (Evolution API como provider)
#############################################

# URLs públicas (onde o usuário acessa no navegador)
APP_URL=https://evo-crm.seudominio.com
FRONTEND_URL=https://evo-crm.seudominio.com
API_URL=https://evo-crm.seudominio.com/api

# Portas locais (dev / caso não use proxy reverso)
FRONTEND_PORT=5173
BACKEND_PORT=3000

# Segurança
JWT_SECRET=change-me-super-secret
JWT_REFRESH_SECRET=change-me-super-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Banco (PostgreSQL)
POSTGRES_USER=evo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=evo_crm
DATABASE_URL=postgresql://evo:change-me@postgres:5432/evo_crm?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Evolution API (container separado)
# - O header usado é `apikey` (Evolution API).
# - A variável AUTHENTICATION_API_KEY é consumida pelo container da Evolution API.
EVOLUTION_API_URL_INTERNAL=http://evolution-api:8080
EVOLUTION_API_URL_PUBLIC=https://evolution-api.seudominio.com
EVOLUTION_API_KEY=change-me
EVOLUTION_WEBHOOK_SECRET=change-me-webhook-secret

# Storage (MinIO)
MINIO_ENABLED=true
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://minio.seudominio.com
MINIO_BUCKET=evo-crm
MAX_MEDIA_SIZE_MB=25

# AI (opcional — desativado por padrão)
AI_ENABLED=false
OPENAI_API_KEY=

# Typebot (opcional)
TYPEBOT_ENABLED=true
TYPEBOT_URL=https://typebot.seudominio.com
TYPEBOT_API_KEY=

# Limites operacionais (segurança e qualidade)
DEFAULT_DAILY_LIMIT_PER_INSTANCE=200
DEFAULT_ALLOWED_START_TIME=08:00
DEFAULT_ALLOWED_END_TIME=20:00
DEFAULT_INTERVAL_MIN_SECONDS=15
DEFAULT_INTERVAL_MAX_SECONDS=60
MAX_ERROR_RATE_PERCENT=5
MAX_OPTOUT_RATE_PERCENT=2
MAX_RETRIES=3
AUTO_PAUSE_ON_INSTABILITY=true

# CORS (apenas domínios HTTPS em produção)
CORS_ORIGINS=https://evo-crm.seudominio.com
# Para dev/local, adicionar: ,http://localhost:5173

# Logs
LOG_LEVEL=info
LOG_PRETTY=false

# Proxy reverso (Traefik)
TRAEFIK_ENABLE=true
TRAEFIK_EMAIL=admin@seudominio.com
TRAEFIK_DOMAIN=evo-crm.seudominio.com
TRAEFIK_EVOLUTION_DOMAIN=evolution-api.seudominio.com
TRAEFIK_MINIO_DOMAIN=minio.seudominio.com

